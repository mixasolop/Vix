<Window x:Class="DesktopAssistant.Frontend.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Desktop Assistant"
        Height="760"
        MinHeight="620"
        Width="1120"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F3F5F7">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D8DEE8" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#647084" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#182232" />

        <Style x:Key="PanelBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="PanelScrollViewerStyle" TargetType="{x:Type ScrollViewer}">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>

        <Style x:Key="DisabledActionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="IsEnabled" Value="False" />
        </Style>

        <DataTemplate x:Key="SimpleLineTemplate">
            <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,8" />
        </DataTemplate>

        <DataTemplate x:Key="StatusItemTemplate">
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Label}" Foreground="{StaticResource MutedTextBrush}" />
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Value}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Text="{Binding Detail}" Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="68" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#172437" Padding="24,0">
            <DockPanel LastChildFill="True">
                <TextBlock Text="Desktop Assistant"
                           VerticalAlignment="Center"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF" />
            </DockPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="16" Padding="0">
            <TabItem Header="Main">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,8,8">
                        <DockPanel LastChildFill="True">
                            <Grid DockPanel.Dock="Bottom" Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="96" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding DraftInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="10,8"
                                         VerticalContentAlignment="Center">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter" Command="{Binding SendCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Grid.Column="1"
                                        Content="Send"
                                        Command="{Binding SendCommand}"
                                        Style="{StaticResource ActionButtonStyle}" />
                            </Grid>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Chat" Style="{StaticResource PanelTitleStyle}" />
                                <ScrollViewer x:Name="ChatScrollViewer"
                                              Grid.Row="1"
                                              Style="{StaticResource PanelScrollViewerStyle}">
                                    <ItemsControl ItemsSource="{Binding ChatMessages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="96" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Speaker}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource PrimaryTextBrush}" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Text}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{StaticResource PrimaryTextBrush}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Margin="8,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Current Plan" Style="{StaticResource PanelTitleStyle}" />
                            <ScrollViewer Grid.Row="1" Style="{StaticResource PanelScrollViewerStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding GoalTitle}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               Margin="0,0,0,14" />
                                    <ItemsControl ItemsSource="{Binding PlanSteps}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayText}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,10"
                                                           Foreground="{StaticResource PrimaryTextBrush}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Margin="0,8,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Tool Trace" Style="{StaticResource PanelTitleStyle}" />
                            <ScrollViewer Grid.Row="1" Style="{StaticResource PanelScrollViewerStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding ToolTracePlaceholder}" Style="{StaticResource MutedTextStyle}" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding ToolTraces}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,10">
                                                    <TextBlock Text="{Binding Tool}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                                                    <TextBlock Text="{Binding Arguments}" Style="{StaticResource MutedTextStyle}" />
                                                    <TextBlock Text="{Binding Status}" Style="{StaticResource MutedTextStyle}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Margin="8,8,0,0">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                <Button Content="Approve" Command="{Binding ApprovePermissionCommand}" Style="{StaticResource ActionButtonStyle}" />
                                <Button Content="Reject" Command="{Binding RejectPermissionCommand}" Style="{StaticResource ActionButtonStyle}" />
                                <Button Content="Edit" Style="{StaticResource DisabledActionButtonStyle}" />
                            </StackPanel>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Permission Drawer" Style="{StaticResource PanelTitleStyle}" />
                                <ScrollViewer Grid.Row="1" Style="{StaticResource PanelScrollViewerStyle}">
                                    <ItemsControl ItemsSource="{Binding PermissionItems}" ItemTemplate="{StaticResource SimpleLineTemplate}" />
                                </ScrollViewer>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Developer">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,8,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Registered Tools" Style="{StaticResource PanelTitleStyle}" />
                            <ScrollViewer Grid.Row="1" Style="{StaticResource PanelScrollViewerStyle}">
                                <StackPanel>
                                    <TextBlock Text="Implemented" FontWeight="SemiBold" Margin="0,0,0,6" />
                                    <ItemsControl ItemsSource="{Binding ImplementedTools}" ItemTemplate="{StaticResource SimpleLineTemplate}" />
                                    <TextBlock Text="Planned" FontWeight="SemiBold" Margin="0,12,0,6" />
                                    <ItemsControl ItemsSource="{Binding PlannedTools}" ItemTemplate="{StaticResource SimpleLineTemplate}" />
                                    <TextBlock Text="Disabled" FontWeight="SemiBold" Margin="0,12,0,6" />
                                    <ItemsControl ItemsSource="{Binding DisabledTools}" ItemTemplate="{StaticResource SimpleLineTemplate}" />
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Margin="8,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Event Log" Style="{StaticResource PanelTitleStyle}" />
                            <ScrollViewer Grid.Row="1" Style="{StaticResource PanelScrollViewerStyle}">
                                <ItemsControl ItemsSource="{Binding EventLogEntries}" ItemTemplate="{StaticResource SimpleLineTemplate}" />
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Margin="0,8,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Failed Actions" Style="{StaticResource PanelTitleStyle}" />
                            <ScrollViewer Grid.Row="1" Style="{StaticResource PanelScrollViewerStyle}">
                                <ItemsControl ItemsSource="{Binding FailedActions}" ItemTemplate="{StaticResource SimpleLineTemplate}" />
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Margin="8,8,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Future Proposed Tools" Style="{StaticResource PanelTitleStyle}" />
                            <ScrollViewer Grid.Row="1" Style="{StaticResource PanelScrollViewerStyle}">
                                <ItemsControl ItemsSource="{Binding FutureProposedTools}" ItemTemplate="{StaticResource SimpleLineTemplate}" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <Grid Margin="0,14,0,0">
                    <Border Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Settings" Style="{StaticResource PanelTitleStyle}" />
                            <ScrollViewer Grid.Row="1" Style="{StaticResource PanelScrollViewerStyle}">
                                <StackPanel MaxWidth="720" HorizontalAlignment="Left">
                                    <ItemsControl ItemsSource="{Binding Settings}" ItemTemplate="{StaticResource StatusItemTemplate}" />
                                    <TextBlock Text="Model selection later"
                                               Style="{StaticResource MutedTextStyle}"
                                               Margin="0,10,0,8" />
                                    <ComboBox SelectedIndex="0" IsEnabled="False" Width="260" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="OpenAI model placeholder" />
                                    </ComboBox>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
